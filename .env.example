# ============================================================
# .env.example — Environment Variable Template
# ============================================================
# Copy this file to .env and fill in your own credentials.
# NEVER commit your actual .env file to GitHub.
#
# HOW TO GET SPOTIFY CREDENTIALS:
#   1. Go to https://developer.spotify.com/dashboard
#   2. Log in and click "Create App"
#   3. Name it anything (e.g. "Underground Music Discovery")
#   4. Set Redirect URI to: http://localhost:8000
#   5. Click Settings and copy your Client ID and Client Secret
# ============================================================

SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
DATABASE_URL=sqlite:///./music_discovery.db